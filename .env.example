# =====================================================================
# Frontend (Vite) — safe to expose to the browser
# =====================================================================
VITE_APP_NAME=Dharul Uloom Kashiful Hudha Arabic College
VITE_APP_DESCRIPTION=A preliminary Arabic educational institution in Kalpitiya, Sri Lanka

# Supabase (browser client). Anon key is protected by Row Level Security.
VITE_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# Legacy Express API (still used by auth/news/etc. during phased migration)
VITE_API_URL=http://localhost:5000

# =====================================================================
# Server-side ONLY — used by scripts/ (never commit real values)
# =====================================================================
# Supabase service role key bypasses RLS. Keep secret.
SUPABASE_URL=https://YOUR-PROJECT.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Shamela API access (request a key from mail@shamela.ws)
SHAMELA_API_KEY=your-shamela-api-key
SHAMELA_BOOKS_ENDPOINT=https://SHAMELA_INSTANCE.ws/api/books
SHAMELA_MASTER_ENDPOINT=https://SHAMELA_INSTANCE.ws/api/master_patch
