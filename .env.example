# =====================================================================
# Frontend (Vite) — safe to expose to the browser
# =====================================================================
VITE_APP_NAME=Dharul Uloom Kashiful Hudha Arabic College
VITE_APP_DESCRIPTION=A preliminary Arabic educational institution in Kalpitiya, Sri Lanka

# Supabase (browser client). Use the HTTPS project URL, NOT a Postgres connection string.
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# Deprecated — frontend no longer calls Express; kept for legacy scripts only
# VITE_API_URL=http://localhost:5000

# =====================================================================
# Server-side ONLY — used by scripts/ and Edge Functions (never commit real values)
# =====================================================================
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
# Personal access token for `npm run deploy:functions` (https://supabase.com/dashboard/account/tokens)
SUPABASE_ACCESS_TOKEN=
SUPABASE_DB_PASSWORD=your-database-password

# PayHere (online fee payments — Sri Lanka)
PAYHERE_MERCHANT_ID=your-merchant-id
PAYHERE_MERCHANT_SECRET=your-merchant-secret
PAYHERE_SANDBOX=true
SITE_URL=http://localhost:3000

# First admin (run once): ADMIN_EMAIL=... ADMIN_PASSWORD=... npm run setup:admin
# Shamela v4 API (optional — needs key from mail@shamela.ws)
SHAMELA_API_KEY=your-shamela-api-key
SHAMELA_BOOKS_ENDPOINT=https://SHAMELA_INSTANCE.ws/api/books
SHAMELA_MASTER_ENDPOINT=https://SHAMELA_INSTANCE.ws/api/master_patch
# Offline full library from Internet Archive (.zip of .bok files, no API key)
SHAMELA_ARCHIVE_URL=https://archive.org/download/shamela_ps/shamela_1441_113_full.zip
# Browse/download page: https://archive.org/details/shamela_ps
# SHAMELA_ARCHIVE_PATH=/path/to/shamela_1441_113_full.zip

# Postgres pooler (Supabase CLI / migrations)
DATABASE_URL=postgresql://postgres.your-ref:[YOUR-PASSWORD]@aws-0-region.pooler.supabase.com:6543/postgres?pgbouncer=true
DIRECT_URL=postgresql://postgres.your-ref:[YOUR-PASSWORD]@aws-0-region.pooler.supabase.com:5432/postgres
