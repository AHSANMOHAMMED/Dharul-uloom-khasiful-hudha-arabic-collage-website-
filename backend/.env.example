# Legacy Express + MongoDB API (optional — frontend uses Supabase directly)
MONGO_URI=mongodb://localhost:27017/kashiful-hudha
PORT=5000
JWT_SECRET=your_jwt_secret_change_in_production
NODE_ENV=development
FRONTEND_URL=http://localhost:3000

# Email (Nodemailer) — only needed if running Express backend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=465
EMAIL_SECURE=true
EMAIL_USER=your_email@example.com
EMAIL_PASS=your_app_password

# Supabase (for backend scripts / helpers)
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
