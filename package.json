{
  "name": "dharul-uloom-kashiful-hudha-website",
  "version": "1.0.0",
  "description": "Official website for Dharul Uloom Kashiful Hudha Arabic College",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:legacy": "concurrently \"npm run dev:frontend\" \"npm run dev:backend\" --names \"FRONTEND,BACKEND\" --prefix-colors \"cyan,green\"",
    "dev:frontend": "vite",
    "dev:backend": "cd backend && npm run dev",
    "build": "vite build",
    "build:backend": "cd backend && npm install",
    "preview": "vite preview",
    "lint": "eslint . --ext js,jsx --report-unused-disable-directives --max-warnings 0",
    "test": "vitest run",
    "import:shamela": "node scripts/shamela/importShamela.mjs",
    "import:shamela:archive": "node scripts/shamela/importShamelaArchive.mjs",
    "upload:book": "node scripts/shamela/manualUpload.mjs",
    "db:apply": "node scripts/applyMigrations.mjs",
    "db:apply:all": "node scripts/applyMigrations.mjs --from=0001",
    "db:seed:library": "node scripts/applyMigrations.mjs --from=0011",
    "setup:admin": "node scripts/setupAdmin.mjs",
    "setup:portal-users": "node scripts/setupPortalUsers.mjs",
    "setup:auth-urls": "node scripts/configureAuthRedirects.mjs",
    "deploy:functions": "node scripts/deployEdgeFunctions.mjs",
    "setup:service-role": "node scripts/setServiceRoleKey.mjs",
    "install:all": "npm install && cd backend && npm install"
  },
  "dependencies": {
    "@hookform/resolvers": "^3.3.2",
    "@supabase/ssr": "^0.10.3",
    "@supabase/supabase-js": "^2.106.2",
    "axios": "^1.6.2",
    "framer-motion": "^10.16.16",
    "i18next": "^23.7.6",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-helmet": "^6.1.0",
    "react-hook-form": "^7.48.2",
    "react-i18next": "^13.5.0",
    "react-router-dom": "^6.20.0",
    "react-toastify": "^9.1.3",
    "recharts": "^2.15.4",
    "yup": "^1.3.3"
  },
  "devDependencies": {
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/react": "^18.2.43",
    "@types/react-dom": "^18.2.17",
    "@vitejs/plugin-react": "^4.2.1",
    "autoprefixer": "^10.4.16",
    "concurrently": "^8.2.2",
    "dotenv": "^17.4.2",
    "eslint": "^8.55.0",
    "eslint-plugin-react": "^7.33.2",
    "eslint-plugin-react-hooks": "^4.6.0",
    "eslint-plugin-react-refresh": "^0.4.5",
    "jsdom": "^24.1.3",
    "p-limit": "^7.3.0",
    "pg": "^8.21.0",
    "postcss": "^8.4.32",
    "shamela": "^1.3.4",
    "tailwindcss": "^3.3.6",
    "vite": "^5.0.8",
    "vitest": "^1.0.4"
  }
}
